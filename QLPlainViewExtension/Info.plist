<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
    <dict>
        <key>NSExtension</key>
        <dict>
            <key>NSExtensionAttributes</key>
            <dict>
                <key>QLIsDataBasedPreview</key>
                <false/>
                <key>QLSupportedContentTypes</key>
                <array>
                    <string>public.text</string>
                    <string>public.data</string>
                    <string>public.yaml</string>
                    <string>public.json</string>
                    <string>public.xml</string>
                    <string>public.comma-separated-values-text</string>
                    <string>public.log</string>
                    <string>public.conf</string>
                    <string>public.ini</string>
                    <string>public.shell-script</string>
                    <string>public.python-script</string>
                    <string>public.ruby-script</string>
                    <string>public.javascript</string>
                    <string>public.typescript</string>
                    <string>public.utf8-plain-text</string>
                    <string>public.utf16-plain-text</string>
                    <string>public.utf16-external-plain-text</string>
                    <string>public.utf8-external-plain-text</string>
                </array>
                <key>QLSupportsSearchableItems</key>
                <false/>
            </dict>
            <key>NSExtensionPointIdentifier</key>
            <string>com.apple.quicklook.preview</string>
            <key>NSExtensionPrincipalClass</key>
            <string>$(PRODUCT_MODULE_NAME).PreviewViewController</string>
        </dict>
    </dict>
</plist>
